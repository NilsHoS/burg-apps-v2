# Supabase project-instellingen voor BURG Apps v2
# Kopieer dit bestand naar .env en vul de echte waarden in.
# Let op: .env staat (of hoort te staan) in .gitignore — commit nooit echte sleutels.

# URL van het Supabase project, bv. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# De "anon" (public) API key van het Supabase project.
# Dit is de client-side sleutel; toegang wordt afgedwongen via RLS-policies,
# niet via geheimhouding van deze key.
VITE_SUPABASE_ANON_KEY=
